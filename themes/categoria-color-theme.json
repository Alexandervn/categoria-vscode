{
  "name": "Categoria",
  "colors": {
    "editor.background": "#222",
    "editor.foreground": "#999",
    "editorBracketHighlight.foreground1": "#999",
    "editorBracketHighlight.foreground2": "#999",
    "editorBracketHighlight.foreground3": "#999",
    "editorBracketHighlight.foreground4": "#999",
    "editorBracketHighlight.foreground5": "#999",
    "editorBracketHighlight.foreground6": "#999"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "variable.other.link.underline.jsdoc"
      ],
      "settings": {
        "foreground": "#666"
      }
    },
    {
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "punctuation.definition.inline.tag.jsdoc",
        "punctuation.definition.bracket.curly.begin.jsdoc",
        "punctuation.definition.bracket.curly.end.jsdoc",
        "entity.name.type.instance.jsdoc",
        "entity.name.type.jsdoc",
        "variable.other.jsdoc",
        "string.other.link.jsdoc",
        "markup.underline.link.jsdoc"
      ],
      "settings": {
        "foreground": "#7c7c7c"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "meta.selector.css",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#e8bb40"
      }
    },
    {
      "scope": [
        "storage",
        "keyword",
        "meta.tag.attributes",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#aad1d6"
      }
    },
    {
      "scope": [
        "variable.other.readwrite",
        "variable.other.property",
        "variable.other.object",
        "meta.var-single-variable.expr",
        "meta.object-binding-pattern-variable",
        "meta.array-binding-pattern-variable",
        "meta.definition.function",
        "meta.definition.method",
        "meta.definition.property",
        "meta.parameters",
        "meta.var.expr",
        "meta.embedded.expression",
        "meta.objectliteral",
        "entity.other.attribute-name",
        "entity.name.type.class",
        "entity.other.inherited-class.ts",
        "variable.other.enummember.ts",
        "meta.enum.declaration.ts",
        "variable.language.this.ts"
      ],
      "settings": {
        "foreground": "#d6d6d6"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#999"
      }
    },
    {
      "scope": ["string", "constant", "keyword.control.anchor.regexp"],
      "settings": {
        "foreground": "#72e6bc"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#ff6895"
      }
    }
  ],
  "semanticHighlighting": false,
  "semanticTokenColors": {
    "class": "#CCC",
    "method": "#e8bb40",
    "function": "#e8bb40"
  }
}
