{
  "name": "Categoria",
  "colors": {
    "editor.background": "#222",
    "editor.foreground": "#d6d6d6",
    "editorBracketHighlight.foreground1": "#999",
    "editorBracketHighlight.foreground2": "#999",
    "editorBracketHighlight.foreground3": "#999",
    "editorBracketHighlight.foreground4": "#999",
    "editorBracketHighlight.foreground5": "#999",
    "editorBracketHighlight.foreground6": "#999"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "variable.other.link.underline.jsdoc"
      ],
      "settings": {
        "foreground": "#666"
      }
    },
    {
      "scope": [
        "storage.type.class.jsdoc",
        "punctuation.definition.block.tag.jsdoc",
        "punctuation.definition.inline.tag.jsdoc",
        "punctuation.definition.bracket.curly.begin.jsdoc",
        "punctuation.definition.bracket.curly.end.jsdoc",
        "entity.name.type.instance.jsdoc",
        "entity.name.type.jsdoc",
        "variable.other.jsdoc",
        "string.other.link.jsdoc",
        "markup.underline.link.jsdoc"
      ],
      "settings": {
        "foreground": "#7c7c7c"
      }
    },
    {
      "scope": [
        "meta.function-call",
        "meta.selector.css",
        "support.class.component",
        "variable.language.this.ts",
        "support.function.misc.css",
        "keyword.control.at-rule.media.css",
        "keyword.control.at-rule.keyframes.css",
        "keyword.control.at-rule.import.css",
        "keyword.control.at-rule.font-face.css",
        "keyword.control.at-rule.supports.css",
        "keyword.control.at-rule.charset.css",
        "keyword.control.at-rule.namespace.css",
        "keyword.control.at-rule.page.css",
        "keyword.control.at-rule.layer.css",
        "keyword.control.at-rule.property.css",
        "keyword.control.at-rule.container.css",
        "keyword.control.at-rule.counter-style.css",
        "keyword.control.at-rule.font-feature-values.css"
      ],
      "settings": {
        "foreground": "#e8bb40"
      }
    },
    {
      "scope": [
        "storage",
        "keyword",
        "meta.tag.attributes",
        "punctuation.accessor",
        "entity.name.tag",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.tsx",
        "meta.tag.attributes.tsx",
        "meta.tag.tsx",
        "support.class.component.tsx",
        "meta.function.variable.css",
        "meta.property-value.css",
        "entity.other.attribute-name.css",
        "entity.other.keyframe-offset.css",
        "punctuation.definition.entity.css",
        "entity.other.attribute-name.pseudo-element.css",
