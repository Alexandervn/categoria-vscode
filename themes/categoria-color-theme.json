    },
    {
      "scope": [
        "variable.other.readwrite",
        "variable.other.property",
        "meta.var-single-variable.expr",
        "meta.object-binding-pattern-variable",
        "meta.array-binding-pattern-variable",
        "meta.definition.function",
        "meta.definition.method",
        "meta.definition.property",
        "meta.parameters",
        "meta.var.expr",
        "meta.embedded.expression",
        "meta.objectliteral",
        "entity.other.attribute-name",
        "entity.other.inherited-class.ts",
        "variable.other.enummember.ts",
        "meta.enum.declaration.ts",
        "variable.argument.css",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#d6d6d6"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#999"
      }
    },
    {
      "scope": [
        "string",
        "constant",
        "keyword.control.anchor.regexp",
        "constant.numeric.css",
        "meta.property-value.css",
        "keyword.other.unit.px.css",
        "keyword.other.unit.em.css",
        "keyword.other.unit.rem.css",
        "keyword.other.unit.vh.css",
        "keyword.other.unit.vw.css",
        "keyword.other.unit.vmin.css",
        "keyword.other.unit.vmax.css",
        "keyword.other.unit.dvh.css",
        "keyword.other.unit.dvw.css",
        "keyword.other.unit.svh.css",
        "keyword.other.unit.svw.css",
        "keyword.other.unit.lvh.css",
        "keyword.other.unit.lvw.css",
        "keyword.other.unit.ch.css",
        "keyword.other.unit.ex.css",
        "keyword.other.unit.lh.css",
        "keyword.other.unit.rlh.css",
        "keyword.other.unit.cap.css",
        "keyword.other.unit.ic.css",
        "keyword.other.unit.cm.css",
        "keyword.other.unit.mm.css",
        "keyword.other.unit.in.css",
        "keyword.other.unit.pt.css",
        "keyword.other.unit.pc.css",
        "keyword.other.unit.q.css",
        "keyword.other.unit.fr.css",
        "keyword.other.unit.deg.css",
        "keyword.other.unit.rad.css",
        "keyword.other.unit.grad.css",
        "keyword.other.unit.turn.css",
        "keyword.other.unit.s.css",
        "keyword.other.unit.ms.css",
        "keyword.other.unit.hz.css",
        "keyword.other.unit.khz.css",
        "keyword.other.unit.dpi.css",
        "keyword.other.unit.dpcm.css",
        "keyword.other.unit.dppx.css",
        "support.constant.font-name.css",
        "support.constant.property-value.css",
        "support.constant.color.current.css"
      ],
      "settings": {
        "foreground": "#72e6bc"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "entity.name.type",
        "entity.name.type.class",
        "entity.other.inherited-class.ts"
      ],
      "settings": {
        "foreground": "#ff6895"
      }
    }
  ],
  "semanticHighlighting": false,
  "semanticTokenColors": {
    "class": "#CCC",
    "method": "#e8bb40",
    "function": "#e8bb40"
  }
}
